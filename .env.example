# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored. Never commit real keys.
#
# WARNING: these keys are inlined into the client bundle at build time
# (see vite.config.ts `define:`). Do NOT deploy the built `dist/` folder
# publicly unless you are comfortable exposing the keys to every visitor.
# For any real deployment, proxy calls through a backend of your own.

GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
